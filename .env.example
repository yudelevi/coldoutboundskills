# Cold Email AI Skills — Environment Variables
#
# Copy this file to .env and fill in the API keys for the skills you'll use.
# You do NOT need all of these — only the ones the skills you invoke depend on.
#
# Minimum for your first campaign: SMARTLEAD + PROSPEO + DYNADOT + ZAPMAIL

# ============================================================
# CORE — always needed
# ============================================================

# Smartlead (sending platform). Sign up: https://smartlead.ai/
# Find key: dashboard → Settings → API. Copy the key.
SMARTLEAD_API_KEY=

# Prospeo (list building). Sign up: https://prospeo.io/
# Find key: dashboard → API. Copy the X-KEY.
PROSPEO_API_KEY=

# ============================================================
# INFRASTRUCTURE — for buying domains + creating inboxes
# ============================================================

# Dynadot (domain registrar). Sign up: https://www.dynadot.com/
# Find key: Account → Tools → API → API Key (request bulk API access if not enabled)
DYNADOT_API_KEY=

# Zapmail (inbox provider). Sign up: https://zapmail.ai/
# Find key: Account → API → Generate token.
ZAPMAIL_API_KEY=

# ============================================================
# EMAIL VALIDATION
# ============================================================

# MillionVerifier (email validation). Sign up: https://www.millionverifier.com/
# Find key: Dashboard → API Key. Needed for auto-research and waterfall.
MILLIONVERIFIER_API_KEY=

# ============================================================
# OPTIONAL — list building alternatives
# ============================================================

# Blitz (domain-to-contacts). Sign up: https://www.useblitz.com/
BLITZ_API_KEY=
BLITZ_BASE_URL=https://api.useblitz.com

# RapidAPI (Google Maps scraping + LinkedIn). Sign up: https://rapidapi.com/
# Then subscribe to:
#   - Maps Data API: https://rapidapi.com/alexanderxbx/api/maps-data
#   - LinkedIn Bulk Data: https://rapidapi.com/apibuilderz/api/realtime-linkedin-bulk-data
RAPIDAPI_KEY=

# ============================================================
# OPTIONAL — alternative sending platform
# ============================================================

# Instantly (alternative to Smartlead). Sign up: https://instantly.ai/
INSTANTLY_API_KEY=

# ============================================================
# OPTIONAL — personalization + enrichment
# ============================================================

# OpenRouter (cheap AI for first-line personalization). Sign up: https://openrouter.ai/
# If using auto-research-public, you do NOT need this — Claude Code does the reasoning.
# Only needed for the cold-email-starter-kit "enrichment" scripts that use OpenRouter.
OPENROUTER_API_KEY=

# OpenWebNinja (company news + blog enrichment). Sign up: https://www.openwebninja.com/
OPENWEBNINJA_KEY=

# ============================================================
# SENDER IDENTITY (used in inbox signatures + from-names)
# ============================================================
# Applied by smartlead-inbox-manager's set-signatures.ts in bulk.
# Default signature template: {from_name} / {title} / {company} / {address}

SENDER_FIRST_NAME=
SENDER_LAST_NAME=
SENDER_TITLE=            # e.g. "Founder", "CEO", "VP of Revenue"
SENDER_COMPANY_NAME=
SENDER_WEBSITE=
SENDER_PHYSICAL_ADDRESS= # REQUIRED for CAN-SPAM. Full mailing address, one line.
